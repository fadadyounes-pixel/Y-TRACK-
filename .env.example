# ─────────────────────────────────────────────────────────────────────────────
# Y-TRACK — TalentMap & IdeaMap Environment Variables
# Copy this file to .env.local and fill in your values.
# All AI providers are optional — the cascade falls through to the next one.
# Only UPSTASH_REDIS_* is required for data persistence in production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Data persistence (Upstash Redis) ─────────────────────────────────────────
# Required for data to persist across sessions in production.
# Free tier: https://console.upstash.com — create a Redis database, copy URL + token.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── AI Providers ──────────────────────────────────────────────────────────────
# Each provider is tried in cascade order; missing keys are skipped.

# Anthropic (claude-haiku-4-5) — best quality — PAID
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# NVIDIA NIM (free — 1 000 credits/month, best free models: DeepSeek-R1-685B, Qwen3-235B, Nemotron-253B)
# https://build.nvidia.com/ → get API key (no credit card)
NVIDIA_API_KEY=

# DeepSeek direct API (near-free — $0.07–0.27 / M tokens, V3 + R1)
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Cerebras — fastest inference (1000-2000 tok/s), 1M tok/day free
# https://cloud.cerebras.ai (no card required)
CEREBRAS_API_KEY=csk-...

# Groq — 30 RPM × 6 models = ~180 RPM effective, permanently free
# https://console.groq.com (no card required)
GROQ_API_KEY=gsk_...

# SambaNova — 200k tok/day, 128k context, best for long documents
# https://cloud.sambanova.ai (no card required)
SAMBANOVA_API_KEY=your_key_here

# Mistral — best French/Arabic quality among open models
# https://console.mistral.ai (free tier, no card)
MISTRAL_API_KEY=your_key_here

# Together AI — free model variants for fallback
# https://api.together.xyz
TOGETHER_API_KEY=your_key_here

# Google Gemini — 15 RPM / 1500 req/day free
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter — 35+ free models, last-resort fallback
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=microsoft/phi-4:free

# ── Optional model overrides ──────────────────────────────────────────────────
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# GEMINI_MODEL=gemini-2.0-flash-lite
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
