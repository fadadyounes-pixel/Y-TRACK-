# ── AI Providers — add keys for providers you want to use ──────────────────
# Each key is optional; missing keys are silently skipped in the cascade.

# Anthropic (claude-haiku-4-5 — primary, highest quality)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini (gemini-2.0-flash — free tier)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (free — 30 RPM per model, 5 models raced in parallel)
# https://console.groq.com/
GROQ_API_KEY=

# NVIDIA NIM (free — 1 000 credits/month, best free models: DeepSeek-R1-685B, Qwen3-235B, Nemotron-253B)
# https://build.nvidia.com/ → get API key (no credit card)
NVIDIA_API_KEY=

# DeepSeek direct API (near-free — $0.07–0.27 / M tokens, V3 + R1)
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Cerebras (free tier — ultra-fast inference)
# https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# SambaNova (free tier)
# https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=

# Mistral (free tier)
# https://console.mistral.ai/
MISTRAL_API_KEY=

# Together AI (free tier)
# https://api.together.xyz/
TOGETHER_API_KEY=

# OpenRouter (free models available — aggregates many providers)
# https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=microsoft/phi-4:free

# ── Database — Upstash Redis (required for TalentMap + IdeaMap data) ────────
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
